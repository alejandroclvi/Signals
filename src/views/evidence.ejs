<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Evidence Library - Signals</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="app">
    <%- include('partials/sidebar', { contexts: contexts, activeContext: activeContext, page: page, stats: stats }) %>

    <main class="main">
      <header class="topbar">
        <div>
          <div class="crumbs">Observations / <%= activeContext.label %></div>
          <div class="title-row">
            <h1>Observations</h1>
          </div>
        </div>
        <div class="top-actions">
          <div class="search-wrap">
            <span>&#8981;</span>
            <input id="evidenceSearch" type="search" placeholder="Search observations…" aria-label="Search observations">
            <kbd>&#8984;K</kbd>
          </div>
        </div>
      </header>

      <div class="filter-toolbar" role="toolbar" aria-label="Filter observations">
        <select class="select" id="filterSource" aria-label="Filter by source">
          <option value="">All sources</option>
          <% for (const src of sources) { %>
            <option value="<%= src %>"><%= src %></option>
          <% } %>
        </select>
        <select class="select" id="filterCommunity" aria-label="Filter by community">
          <option value="">All communities</option>
          <% for (const c of communities) { %>
            <option value="<%= c %>"><%= c %></option>
          <% } %>
        </select>
        <select class="select" id="filterIntent" aria-label="Filter by intent">
          <option value="">All intents</option>
          <% for (const i of intents) { %>
            <option value="<%= i %>"><%= i %></option>
          <% } %>
        </select>
        <select class="select" id="filterAwareness" aria-label="Filter by awareness">
          <option value="">All awareness</option>
          <option value="unaware">Unaware</option>
          <option value="problem_aware">Problem Aware</option>
          <option value="solution_aware">Solution Aware</option>
          <option value="product_aware">Product Aware</option>
          <option value="most_aware">Most Aware</option>
        </select>
        <select class="select" id="filterSentiment" aria-label="Filter by sentiment">
          <option value="">All sentiment</option>
          <option value="positive">Positive</option>
          <option value="negative">Negative</option>
          <option value="neutral">Neutral</option>
          <option value="mixed">Mixed</option>
        </select>
      </div>

      <div class="evidence-library-header">
        <span class="evidence-count"><%= evidence.length %> evidence packets</span>
        <div class="view-toggle">
          <button class="view-btn active" data-view="thread" id="viewThread">Thread view</button>
          <button class="view-btn" data-view="flat" id="viewFlat">Flat view</button>
        </div>
      </div>

      <div class="evidence-library" id="evidenceLibrary">
        <% if (!evidence.length) { %>
          <div class="empty-state">
            <div class="empty-icon">&#9636;</div>
            <div class="empty-title">No evidence yet</div>
            <div class="empty-sub">Evidence packets will appear here once data is ingested.</div>
          </div>
        <% } else { %>

          <%
            const stateExplanationsServer = {
              experiencing_pain: "Describing a problem they feel — raw pain language.",
              tried_failed: "Used a tool and it didn't work — competitive intelligence.",
              seeking: "Actively looking for a solution — demand signal.",
              found_what_works: "Found something that works — adoption signal.",
              warning: "Telling others to avoid — community-validated failure.",
              sharing_insight: "Sharing knowledge or experience.",
              comparing: "Evaluating tools or approaches — competitive landscape.",
              promoting: "Promoting their own product.",
            };

            function extractStateExcerptServer(body, state) {
              const explanation = stateExplanationsServer[state] || '';
              if (!body) return explanation;
              const text = body.replace(/\n+/g, ' ').trim();
              const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];
              const patterns = {
                experiencing_pain: /frustrat|annoying|hate|terrible|broken|expensive|struggling|waste|useless|nightmare/i,
                tried_failed: /tried|used|tested|didn't work|waste|terrible|garbage/i,
                seeking: /looking for|is there|has anyone|recommend|any tool|how do you|need/i,
                found_what_works: /game.changer|love|works great|recommend|worth|saved/i,
                warning: /don't waste|stay away|avoid|wouldn't recommend|save your|worst/i,
                sharing_insight: /learned|realized|turns out|the key|what worked|experience|tip/i,
                comparing: /vs|versus|compared|alternative|switch|better than/i,
                promoting: /built|created|launched|check out|announcing/i,
              };
              const pat = patterns[state];
              let quote = '';
              if (pat) {
                const found = sentences.find(s => pat.test(s));
                if (found) quote = found.trim().slice(0, 100);
              }
              if (!quote) quote = sentences[0] ? sentences[0].trim().slice(0, 80) : '';
              return explanation + ' — &quot;' + quote + '&quot;';
            }
          %>

          <%
            // Group evidence by thread_id for thread view
            const threads = new Map();
            const orphans = [];
            for (const ep of evidence) {
              if (ep.thread_id) {
                if (!threads.has(ep.thread_id)) threads.set(ep.thread_id, []);
                threads.get(ep.thread_id).push(ep);
              } else {
                orphans.push(ep);
              }
            }
            // Sort each thread: post first (t3_), then comments by score
            for (const [tid, packets] of threads) {
              packets.sort((a, b) => {
                const aIsPost = (a.source_item_id || '').startsWith('t3_');
                const bIsPost = (b.source_item_id || '').startsWith('t3_');
                if (aIsPost && !bIsPost) return -1;
                if (!aIsPost && bIsPost) return 1;
                try {
                  const aScore = JSON.parse(a.metrics || '{}').score || 0;
                  const bScore = JSON.parse(b.metrics || '{}').score || 0;
                  return bScore - aScore;
                } catch { return 0; }
              });
            }
            // Sort threads by top post score
            const sortedThreads = [...threads.entries()].sort((a, b) => {
              try {
                const aScore = JSON.parse(a[1][0].metrics || '{}').score || 0;
                const bScore = JSON.parse(b[1][0].metrics || '{}').score || 0;
                return bScore - aScore;
              } catch { return 0; }
            });
          %>

          <!-- Thread view -->
          <div id="threadView" class="thread-view">
            <% for (const [threadId, packets] of sortedThreads) { %>
              <% const post = packets[0]; %>
              <% const comments = packets.slice(1); %>
              <% let pm; try { pm = JSON.parse(post.metrics || '{}'); } catch { pm = {}; } %>
              <div class="thread-group" data-thread="<%= threadId %>" data-community="<%= post.community %>" data-source="<%= post.source_id %>">
                <!-- Post (root node) -->
                <%
                  const postIntentColors = { pain: '#de5c56', question: '#2d6fbb', insight: '#3e9558', comparison: '#bd842f', promotion: '#9aa3ad' };
                  const postIntentColor = postIntentColors[post.intent] || '#3e9558';
                %>
                <div class="thread-root evidence-row" data-intent="<%= post.intent || '' %>" data-awareness="<%= post.awareness_level || '' %>" data-sentiment="<%= post.sentiment || '' %>">
                  <div class="thread-branch-root"></div>
                  <div class="thread-node" style="border-left: 3px solid <%= postIntentColor %>; padding-left: 12px">
                    <div class="thread-node-head">
                      <span class="mini-chip"><%= post.community || '' %></span>
                      <span class="thread-score">&#9650; <%= pm.score || 0 %></span>
                      <span class="thread-comments-count"><%= comments.length %> comments</span>
                      <%
                        const postStateColors = { experiencing_pain:'#de5c56', tried_failed:'#c0392b', seeking:'#2d6fbb', found_what_works:'#3e9558', warning:'#e67e22', sharing_insight:'#875fb4', comparing:'#bd842f', promoting:'#9aa3ad' };
                        const postStateLabels = { experiencing_pain:'Pain', tried_failed:'Tried & failed', seeking:'Seeking', found_what_works:'Works', warning:'Warning', sharing_insight:'Insight', comparing:'Comparing', promoting:'Promo' };
                        const postEvState = post.evidence_state || 'sharing_insight';
                        const postEvColor = postStateColors[postEvState] || '#9aa3ad';
                        const postEvLabel = postStateLabels[postEvState] || postEvState;
                        const postExcerpt = extractStateExcerptServer(post.body, postEvState);
                      %>
                      <span class="mini-chip evidence-chip" style="background: <%= postEvColor %>18; color: <%= postEvColor %>; font-size:10px; border: 1px solid <%= postEvColor %>30" data-chip-excerpt="<%= postExcerpt %>"><%= postEvLabel %></span>
                      <span class="thread-author"><%= post.author_ref || '' %></span>
                      <span class="thread-date"><%= post.published_at ? new Date(post.published_at).toLocaleDateString() : '' %></span>
                      <% if (post.url && post.url !== '#') { %><a href="<%= post.url %>" target="_blank" rel="noopener" class="thread-source">source &#8250;</a><% } %>
                    </div>
                    <div class="thread-title"><% if (post.url && post.url !== '#') { %><a href="<%= post.url %>" target="_blank" rel="noopener"><%= post.title || '' %></a><% } else { %><%= post.title || '' %><% } %></div>
                    <div class="thread-body"><%= (post.body || '').slice(0, 300) %><%= (post.body || '').length > 300 ? '...' : '' %></div>
                  </div>
                </div>
                <% const topInsight = threadInsights[threadId] || ''; %>
                <% if (topInsight) { %>
                <div class="thread-insight-banner">
                  <span class="thread-insight-icon">&#9672;</span>
                  <span class="thread-insight-text"><%= topInsight %></span>
                </div>
                <% } %>
                <!-- Comments (branches) — collapse if >3 -->
                <%
                  const shouldCollapse = comments.length > 3;
                  const visibleIndices = shouldCollapse
                    ? [0, 1, comments.length - 1]
                    : comments.map((_, i) => i);
                  const hiddenCount = shouldCollapse ? comments.length - 3 : 0;
                  const tInsight = threadInsights[threadId] || '';
                %>
                <% for (let ci = 0; ci < comments.length; ci++) { %>
                  <% const isVisible = visibleIndices.includes(ci); %>
                  <% if (shouldCollapse && ci === 2) { %>
                    <!-- Collapsed summary -->
                    <div class="ev-collapsed" data-thread-page-expand="<%= threadId %>">
                      <div class="ev-branch"><div class="ev-branch-line"></div><div class="ev-branch-arm" style="border-style:dashed"></div></div>
                      <div class="ev-collapsed-body">
                        <% if (tInsight) { %><div class="ev-collapsed-insight"><%= tInsight %></div><% } %>
                        <button class="ev-expand-btn-page" data-expand-thread="<%= threadId %>"><%= hiddenCount %> more replies — click to expand</button>
                      </div>
                    </div>
                  <% } %>
                  <% const c = comments[ci]; %>
                  <% let cm; try { cm = JSON.parse(c.metrics || '{}'); } catch { cm = {}; } %>
                  <% const isLast = ci === comments.length - 1; %>
                  <% const isHidden = shouldCollapse && ci >= 2 && ci < comments.length - 1; %>
                  <%
                    const intentColors = { pain: '#de5c56', question: '#2d6fbb', insight: '#3e9558', comparison: '#bd842f', promotion: '#9aa3ad' };
                    const intentColor = intentColors[c.intent] || '#dfe4ea';
                  %>
                  <div class="thread-comment evidence-row<%= isHidden ? ' thread-hidden-comment' : '' %><%= shouldCollapse && isLast ? ' ev-last-peek' : '' %>" data-intent="<%= c.intent || '' %>" data-awareness="<%= c.awareness_level || '' %>" data-sentiment="<%= c.sentiment || '' %>" data-thread-parent="<%= threadId %>" <%= isHidden ? 'style="display:none"' : '' %>>
                    <div class="thread-branch <%= isLast ? 'thread-branch-last' : '' %>">
                      <div class="thread-branch-line"></div>
                      <div class="thread-branch-arm"></div>
                    </div>
                    <div class="thread-node thread-node-comment" style="border-left: 2px solid <%= intentColor %>">
                      <div class="thread-node-head">
                        <span class="thread-score">&#9650; <%= cm.score || 0 %></span>
                        <%
                        const cStateColors = { experiencing_pain:'#de5c56', tried_failed:'#c0392b', seeking:'#2d6fbb', found_what_works:'#3e9558', warning:'#e67e22', sharing_insight:'#875fb4', comparing:'#bd842f', promoting:'#9aa3ad' };
                        const cStateLabels = { experiencing_pain:'Pain', tried_failed:'Tried & failed', seeking:'Seeking', found_what_works:'Works', warning:'Warning', sharing_insight:'Insight', comparing:'Comparing', promoting:'Promo' };
                        const cEvState = c.evidence_state || 'sharing_insight';
                        const cEvColor = cStateColors[cEvState] || '#9aa3ad';
                        const cEvLabel = cStateLabels[cEvState] || cEvState;
                        const cExcerpt = extractStateExcerptServer(c.body, cEvState);
                      %>
                      <span class="mini-chip evidence-chip" style="background: <%= cEvColor %>18; color: <%= cEvColor %>; font-size:10px; border: 1px solid <%= cEvColor %>30" data-chip-excerpt="<%= cExcerpt %>"><%= cEvLabel %></span>
                        <span class="thread-author"><%= c.author_ref || '' %></span>
                        <% if (c.url && c.url !== '#') { %><a href="<%= c.url %>" target="_blank" rel="noopener" class="thread-source">source &#8250;</a><% } %>
                      </div>
                      <div class="thread-body"><%= (c.body || '').slice(0, 250) %><%= (c.body || '').length > 250 ? '...' : '' %></div>
                    </div>
                  </div>
                <% } %>
              </div>
            <% } %>

            <% if (orphans.length > 0) { %>
              <% const ORPHAN_CAP = 500; const orphansShown = orphans.slice(0, ORPHAN_CAP); %>
              <div class="thread-group" id="unthreadedGroup" data-source="" data-community="">
                <div class="thread-group-label" id="unthreadedLabel">
                  Unthreaded evidence
                  <span class="thread-group-count" id="unthreadedCount"
                        data-shown="<%= orphansShown.length %>" data-total="<%= orphans.length %>">
                    (<%= orphansShown.length === orphans.length ? orphans.length : orphansShown.length + ' of ' + orphans.length %>)
                  </span>
                </div>
                <% for (const ep of orphansShown) { %>
                  <% let m; try { m = JSON.parse(ep.metrics || '{}'); } catch { m = {}; } %>
                  <div class="thread-root evidence-row" data-source="<%= ep.source_id %>" data-community="<%= ep.community %>" data-intent="<%= ep.intent || '' %>" data-awareness="<%= ep.awareness_level || '' %>">
                    <div class="thread-branch-root"></div>
                    <div class="thread-node">
                      <div class="thread-node-head">
                        <span class="mini-chip"><%= ep.community || '' %></span>
                        <span class="thread-score">&#9650; <%= m.score || 0 %></span>
                        <span class="thread-author"><%= ep.author_ref || '' %></span>
                      </div>
                      <div class="thread-body"><%= (ep.body || '').slice(0, 200) %></div>
                    </div>
                  </div>
                <% } %>
                <div class="empty-state" id="unthreadedEmpty" style="display:none;padding:20px;text-align:center;color:var(--muted);font-size:12px">
                  No unthreaded evidence matches the current filter.
                  <% if (orphans.length > ORPHAN_CAP) { %>
                    Only the first <%= ORPHAN_CAP %> of <%= orphans.length %> unthreaded packets are loaded — the match may live in the rest.
                  <% } %>
                </div>
              </div>
            <% } %>
          </div>

          <!-- Flat view (original table) -->
          <table class="evidence-table" id="flatView" style="display:none">
            <thead>
              <tr>
                <th>Source</th>
                <th>Community</th>
                <th>Content</th>
                <th>Author</th>
                <th>Score</th>
                <th>Awareness</th>
                <th>Signal</th>
                <th>Date</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="evidenceBody">
              <% for (const ep of evidence) { %>
                <% let m; try { m = JSON.parse(ep.metrics || '{}'); } catch { m = {}; } %>
                <tr class="evidence-row" data-source="<%= ep.source_id %>" data-community="<%= ep.community %>" data-intent="<%= ep.intent || '' %>" data-awareness="<%= ep.awareness_level || '' %>">
                  <td><span class="mini-chip"><%= ep.source_id %></span></td>
                  <td class="evidence-community"><%= ep.community || '-' %></td>
                  <td class="evidence-content">
                    <div class="evidence-title"><% if (ep.url && ep.url !== '#') { %><a href="<%= ep.url %>" target="_blank" rel="noopener"><%= ep.title || '' %></a><% } else { %><%= ep.title || '' %><% } %></div>
                    <div class="evidence-body"><%= ep.body || '' %></div>
                  </td>
                  <td class="evidence-author"><%= ep.author_ref || '-' %></td>
                  <td class="evidence-score">&#9650; <%= m.score || 0 %></td>
                  <td><% if (ep.awareness_level) { %><span class="mini-chip awareness-<%= ep.awareness_level %>"><%= ep.awareness_level.replace(/_/g, ' ') %></span><% } %></td>
                  <td>
                    <% if (ep.signal_title) { %>
                      <a href="/?context=<%= activeContext.id %>#<%= ep.signal_id %>" class="evidence-signal-link" title="View in radar"><%= ep.signal_title %></a>
                    <% } else { %>
                      <span class="faint">unlinked</span>
                    <% } %>
                  </td>
                  <td class="evidence-date"><%= ep.published_at ? new Date(ep.published_at).toLocaleDateString() : 'replay' %></td>
                  <td>
                    <% if (ep.url && ep.url !== '#') { %>
                      <a href="<%= ep.url %>" target="_blank" rel="noopener" class="evidence-source-link">source &#8250;</a>
                    <% } else { %>
                      <span class="faint">replay</span>
                    <% } %>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        <% } %>
      </div>
    </main>
  </div>

  <script>
    // Client-side filtering
    var searchInput = document.getElementById("evidenceSearch");
    var filterSource = document.getElementById("filterSource");
    var filterCommunity = document.getElementById("filterCommunity");
    var filterIntent = document.getElementById("filterIntent");
    var filterAwareness = document.getElementById("filterAwareness");
    var filterSentiment = document.getElementById("filterSentiment");

    function filterEvidence() {
      var term = (searchInput.value || "").trim().toLowerCase();
      var source = filterSource.value;
      var community = filterCommunity.value;
      var intent = filterIntent.value;
      var awareness = filterAwareness ? filterAwareness.value : "";
      var sentiment = filterSentiment ? filterSentiment.value : "";

      // Filter flat view rows
      var rows = document.querySelectorAll(".evidence-row");
      var visible = 0;
      rows.forEach(function(row) {
        var matchText = !term || row.textContent.toLowerCase().includes(term);
        var matchSource = !source || row.dataset.source === source;
        var matchComm = !community || row.dataset.community === community;
        var matchIntent = !intent || row.dataset.intent === intent;
        var matchAwareness = !awareness || row.dataset.awareness === awareness;
        var matchSentiment = !sentiment || row.dataset.sentiment === sentiment;
        var show = matchText && matchSource && matchComm && matchIntent && matchAwareness && matchSentiment;
        row.style.display = show ? "" : "none";
        if (show) visible++;
      });

      // Filter thread groups — show group if any child matches
      var groups = document.querySelectorAll(".thread-group");
      groups.forEach(function(group) {
        // The unthreaded group has empty data attrs so it never gets filtered
        // by source/community at the group level — only its children do.
        var isUnthreaded = group.id === "unthreadedGroup";
        var matchComm = isUnthreaded || !community || group.dataset.community === community;
        var matchSource = isUnthreaded || !source || group.dataset.source === source;
        var childRows = group.querySelectorAll(".evidence-row");
        var visibleChildren = 0;
        childRows.forEach(function(r) { if (r.style.display !== "none") visibleChildren++; });
        // For the unthreaded group, swap its body for an empty-state when no
        // children match; keep the group itself mounted so the label can
        // explain why nothing is showing.
        if (isUnthreaded) {
          var emptyEl = document.getElementById("unthreadedEmpty");
          var countEl = document.getElementById("unthreadedCount");
          if (emptyEl) emptyEl.style.display = visibleChildren === 0 ? "" : "none";
          if (countEl) {
            var total = countEl.dataset.total;
            var anyFilter = !!(community || source || intent || awareness || sentiment || term);
            countEl.textContent = anyFilter
              ? "(" + visibleChildren + " of " + total + " matching)"
              : "(" + countEl.dataset.shown + (countEl.dataset.shown !== total ? " of " + total : "") + ")";
          }
        } else {
          group.style.display = (matchComm && matchSource && visibleChildren > 0) ? "" : "none";
        }
      });

      document.querySelector(".evidence-count").textContent = visible + " evidence packets";
    }

    // Pre-select filter from URL params
    var params = new URLSearchParams(window.location.search);
    if (params.get("community") && filterCommunity) {
      filterCommunity.value = params.get("community");
    }
    if (params.get("intent") && filterIntent) {
      filterIntent.value = params.get("intent");
    }
    if (params.get("awareness") && filterAwareness) {
      filterAwareness.value = params.get("awareness");
    }

    if (searchInput) searchInput.addEventListener("input", filterEvidence);
    if (filterSource) filterSource.addEventListener("change", filterEvidence);
    if (filterCommunity) filterCommunity.addEventListener("change", filterEvidence);
    if (filterIntent) filterIntent.addEventListener("change", filterEvidence);
    if (filterAwareness) filterAwareness.addEventListener("change", filterEvidence);
    if (filterSentiment) filterSentiment.addEventListener("change", filterEvidence);

    // Apply initial filter if URL params set
    if (params.get("community") || params.get("intent") || params.get("awareness")) filterEvidence();

    // View toggle: thread vs flat
    var viewThread = document.getElementById("viewThread");
    var viewFlat = document.getElementById("viewFlat");
    var threadViewEl = document.getElementById("threadView");
    var flatViewEl = document.getElementById("flatView");

    if (viewThread && viewFlat) {
      viewThread.addEventListener("click", function() {
        viewThread.classList.add("active");
        viewFlat.classList.remove("active");
        if (threadViewEl) threadViewEl.style.display = "";
        if (flatViewEl) flatViewEl.style.display = "none";
      });
      viewFlat.addEventListener("click", function() {
        viewFlat.classList.add("active");
        viewThread.classList.remove("active");
        if (threadViewEl) threadViewEl.style.display = "none";
        if (flatViewEl) flatViewEl.style.display = "";
      });
    }

    // Thread expand buttons
    document.querySelectorAll('.ev-expand-btn-page').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var threadId = btn.dataset.expandThread;
        var hiddenComments = document.querySelectorAll('[data-thread-parent="' + threadId + '"].thread-hidden-comment');
        hiddenComments.forEach(function(el) { el.style.display = ''; el.classList.remove('thread-hidden-comment'); });
        var collapsed = btn.closest('.ev-collapsed');
        if (collapsed) collapsed.remove();
        // Remove last-peek dimming
        var lastPeek = document.querySelector('[data-thread-parent="' + threadId + '"].ev-last-peek');
        if (lastPeek) lastPeek.classList.remove('ev-last-peek');
      });
    });

    // Evidence chip hover cards
    (function() {
      var hoverTimer = null;
      var leaveTimer = null;
      var activeCard = null;

      function removeCard() {
        if (activeCard) { activeCard.remove(); activeCard = null; }
      }

      function showChipCard(chip) {
        removeCard();
        var excerpt = chip.dataset.chipExcerpt;
        if (!excerpt) return;

        var label = chip.textContent.trim();
        var isAwareness = chip.classList.contains('awareness-problem_aware') || chip.classList.contains('awareness-solution_aware') || chip.classList.contains('awareness-product_aware') || chip.classList.contains('awareness-most_aware') || chip.classList.contains('awareness-unaware');
        var color = isAwareness ? (getComputedStyle(chip).color || '#68717d') : (chip.style.color || '#68717d');

        var card = document.createElement('div');
        card.className = 'chip-hover-card';
        card.innerHTML = '<div class="chip-hover-label" style="color:' + color + '">' + label + '</div>' +
          '<div class="chip-hover-excerpt">' + excerpt.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</div>';
        document.body.appendChild(card);
        activeCard = card;

        var rect = chip.getBoundingClientRect();
        var cardRect = card.getBoundingClientRect();
        var left = rect.left;
        var top = rect.bottom + 4;
        if (left + cardRect.width > window.innerWidth - 12) left = window.innerWidth - cardRect.width - 12;
        if (top + cardRect.height > window.innerHeight - 12) top = rect.top - cardRect.height - 4;
        card.style.left = left + 'px';
        card.style.top = top + 'px';

        card.addEventListener('mouseenter', function() { clearTimeout(leaveTimer); });
        card.addEventListener('mouseleave', function() { leaveTimer = setTimeout(removeCard, 120); });
      }

      document.addEventListener('mouseenter', function(e) {
        var chip = e.target.closest('.evidence-chip');
        if (!chip || !chip.dataset.chipExcerpt) return;
        clearTimeout(leaveTimer);
        hoverTimer = setTimeout(function() { showChipCard(chip); }, 180);
      }, true);

      document.addEventListener('mouseleave', function(e) {
        var chip = e.target.closest('.evidence-chip');
        if (!chip) return;
        clearTimeout(hoverTimer);
        leaveTimer = setTimeout(removeCard, 120);
      }, true);
    })();

    // Context switching
    var contextSelect = document.getElementById("contextSelect");
    if (contextSelect) {
      contextSelect.addEventListener("change", function(e) {
        window.location.href = "/evidence?context=" + encodeURIComponent(e.target.value);
      });
    }

    // New context button
    var btnNew = document.getElementById("btnNewContext");
    if (btnNew) btnNew.addEventListener("click", function() {
      if (typeof openNewContextModal === "function") openNewContextModal();
    });
  </script>
</body>
</html>
