<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Lens: <%= lensInfo.label %> — Signals</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .lens-header { display: flex; align-items: baseline; gap: 16px; margin-bottom: 8px; }
    .lens-pill { display: inline-block; padding: 2px 10px; border-radius: 999px; background: #eef; color: #335; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    .lens-desc { color: var(--faint); margin: 0 0 24px; max-width: 720px; }
    .lens-tabs { display: flex; gap: 6px; margin-bottom: 24px; flex-wrap: wrap; }
    .lens-tab { padding: 6px 14px; border-radius: 8px; background: #f5f5f7; color: #333; text-decoration: none; font-size: 13px; }
    .lens-tab.active { background: #1a1a1a; color: white; }
    .signal-row { display: grid; grid-template-columns: 60px 1fr 80px 100px; align-items: center; gap: 16px; padding: 14px 16px; border-bottom: 1px solid #eee; }
    .signal-row:hover { background: #fafafa; }
    .signal-rank { font-size: 22px; font-weight: 600; color: #888; text-align: right; }
    .signal-title { font-size: 14px; font-weight: 500; }
    .signal-meta { font-size: 12px; color: var(--faint); margin-top: 4px; }
    .signal-score { font-variant-numeric: tabular-nums; font-weight: 600; text-align: right; }
    .signal-status { font-size: 12px; padding: 3px 8px; border-radius: 4px; background: #f1f3f5; color: #555; text-align: center; }
    .components-mini { font-family: ui-monospace, monospace; font-size: 11px; color: #888; margin-top: 6px; }
  </style>
</head>
<body>
  <div class="app">
    <%- include('partials/sidebar', { contexts: contexts, activeContext: activeContext, page: page, stats: stats }) %>

    <main class="main">
      <header class="topbar">
        <div>
          <div class="crumbs">Lens / <%= activeContext.label %></div>
          <div class="title-row lens-header">
            <h1><%= lensInfo.label %></h1>
            <span class="lens-pill"><%= lensInfo.id %></span>
          </div>
          <p class="lens-desc"><%= lensInfo.description %></p>
          <div class="lens-tabs">
            <% allLenses.forEach(l => { %>
              <a class="lens-tab <%= l.id === lensInfo.id ? 'active' : '' %>" href="/lens/<%= l.id %>?context=<%= activeContext.id %>"><%= l.label %></a>
            <% }) %>
          </div>
        </div>
      </header>

      <% if (!signals.length) { %>
        <div class="empty-state" style="padding: 40px; text-align: center; color: var(--faint);">
          <p>No lens scores yet for this context.</p>
          <p style="font-size: 13px;">Run <code style="background:#f1f3f5;padding:2px 6px;border-radius:4px">node -e "import('./src/pipeline/lens-scorer.mjs').then(m=>m.scoreContextAllLenses('<%= activeContext.id %>'))"</code></p>
        </div>
      <% } else { %>
        <div class="signal-list">
          <% signals.forEach(s => { %>
            <div class="signal-row">
              <div class="signal-rank">#<%= s.rank_in_ctx %></div>
              <div>
                <div class="signal-title"><%= s.title %></div>
                <div class="signal-meta">
                  <%= s.dominant_state || 'unclassified' %> · <%= s.mentions %> mentions
                  <% if (s.topComponents?.length) { %>
                    <div class="components-mini">
                      <% s.topComponents.forEach(c => { %>
                        <span title="weight × raw"><%= c.name.slice(0, 22) %>:<%= c.weighted %></span> ·
                      <% }) %>
                    </div>
                  <% } %>
                </div>
              </div>
              <div class="signal-score"><%= Math.round(s.total) %></div>
              <div class="signal-status"><%= s.status || 'Emerging' %></div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </main>
  </div>
</body>
</html>
