<header class="topbar">
  <div>
    <div class="crumbs" id="crumbs">Radar / <%= activeContext.label %></div>
    <div class="title-row">
      <h1>Signal Radar</h1>
      <span class="live-dot" aria-hidden="true"></span>
      <span class="live-text">Live</span>
    </div>
  </div>
  <div class="top-actions">
    <div class="search-wrap">
      <span>&#8981;</span>
      <input id="searchInput" type="search" placeholder="Search topics, phrases, communities..." aria-label="Search signals">
      <kbd>&#8984;K</kbd>
    </div>
    <% let hasReddit = false; try { hasReddit = JSON.parse(activeContext.subreddits || '[]').length > 0; } catch(e) {} %>
    <% if (hasReddit) { %>
    <button class="button" type="button" id="btnRefresh" title="Pull live Reddit data">&#8635; Refresh</button>
    <% } %>
  </div>
</header>
