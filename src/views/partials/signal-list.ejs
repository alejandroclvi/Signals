<section class="context-brief" id="contextBrief"></section>

<section class="dashboard-grid">
  <div class="board">
    <div class="panel-head">
      <div>
        <h2 class="panel-title">Signal Radar <span class="panel-sub" id="topicSummary"></span></h2>
      </div>
      <div class="legend">
        <span class="legend-item" data-tag="demand"><i class="dot" style="background:var(--green)"></i> Demand</span>
        <span class="legend-item" data-tag="frustration"><i class="dot" style="background:var(--red)"></i> Frustration</span>
        <span class="legend-item" data-tag="adoption"><i class="dot" style="background:var(--blue)"></i> Adoption</span>
        <span class="legend-item" data-tag="comparison"><i class="dot" style="background:var(--gold)"></i> Comparison</span>
        <span class="legend-item" data-tag="narrative"><i class="dot" style="background:var(--purple)"></i> Narrative</span>
        <span class="legend-item" data-tag="economic"><i class="dot" style="background:var(--teal)"></i> Economic</span>
      </div>
    </div>
    <div class="bubble-zone" id="bubbleZone">
      <svg class="bubble-svg" id="bubbleSvg" role="img" aria-label="Signal radar chart"></svg>
    </div>
    <!-- chart-row hidden — radar chart is the primary view -->
    <div class="chart-row" style="display:none">
      <div class="chart-card">
        <div class="chart-title"><strong>Momentum Timeline</strong><span>30d</span></div>
        <svg class="line-chart" id="timelineSvg" viewBox="0 0 430 142" role="img"></svg>
      </div>
      <div class="chart-card">
        <div class="chart-title"><strong>Community Spread</strong><span>weekly</span></div>
        <svg class="heatmap-chart" id="heatmapSvg" viewBox="0 0 330 142" role="img"></svg>
      </div>
      <div class="chart-card">
        <div class="chart-title"><strong>Intent Breakdown</strong><span>classified</span></div>
        <div id="intentBars"></div>
      </div>
    </div>
  </div>

  <aside class="inbox">
    <div class="panel-head">
      <h2 class="panel-title">Signal Inbox</h2>
      <div class="legend"><span>&#9661;</span><span>...</span></div>
    </div>
    <div class="inbox-tabs">
      <button class="inbox-tab active" type="button">Ranked <span class="tab-count" id="rankedCount">0</span></button>
      <button class="inbox-tab" type="button">New <span class="tab-count">-</span></button>
      <button class="inbox-tab" type="button">Saved <span class="tab-count" id="savedCount">0</span></button>
    </div>
    <div class="intent-filters" id="intentFilters">
      <button class="intent-btn active" type="button" data-intent="all">All</button>
      <button class="intent-btn" type="button" data-intent="experiencing_pain" style="--btn-color:#de5c56">Pain</button>
      <button class="intent-btn" type="button" data-intent="seeking" style="--btn-color:#2d6fbb">Seeking</button>
      <button class="intent-btn" type="button" data-intent="tried_failed" style="--btn-color:#c0392b">Failed</button>
      <button class="intent-btn" type="button" data-intent="sharing_insight" style="--btn-color:#875fb4">Insight</button>
      <button class="intent-btn" type="button" data-intent="comparing" style="--btn-color:#bd842f">Compare</button>
      <button class="intent-btn" type="button" data-intent="warning" style="--btn-color:#e67e22">Warning</button>
    </div>
    <div class="signal-list" id="signalList"></div>
  </aside>
</section>
