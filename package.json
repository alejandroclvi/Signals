{
  "name": "signals",
  "version": "0.1.0",
  "type": "module",
  "description": "Early-warning system for detecting internet momentum",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "demo": "node scripts/setup.mjs && node src/server.mjs",
    "doctor": "node scripts/doctor.mjs",
    "dev": "node --watch src/server.mjs",
    "start": "node src/server.mjs",
    "stop": "node scripts/stop.mjs",
    "refresh": "node scripts/refresh.mjs",
    "restore": "node scripts/restore.mjs",
    "sync-source-nodes": "node scripts/sync-source-nodes.mjs",
    "sync-watchlist": "node scripts/sync-watchlist.mjs",
    "brief": "node scripts/generate-research-brief.mjs",
    "brief:unified": "node scripts/flow.mjs run unify-signals --context",
    "flow": "node scripts/flow.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "migrate": "node src/db/migrate.mjs",
    "seed": "node scripts/seed-fixtures.mjs",
    "seed:market": "node scripts/seed-market-fixtures.mjs",
    "seed:all": "node scripts/seed-fixtures.mjs && node scripts/seed-market-fixtures.mjs",
    "ingest": "node scripts/ingest-cli.mjs",
    "ingest:multi": "node scripts/ingest-multi.mjs",
    "thread-intel": "node scripts/run-thread-intelligence.mjs",
    "research": "node scripts/research-loop.mjs",
    "reclassify": "node scripts/reclassify-llm.mjs",
    "theme-labels": "node scripts/generate-theme-labels-cli.mjs",
    "backfill": "node scripts/backfill-classifications.mjs",
    "graph:sync": "node scripts/sync-graph.mjs",
    "report:weekly": "node scripts/weekly-report.mjs",
    "push": "node scripts/push-report.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
