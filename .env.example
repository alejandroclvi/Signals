# Signals environment — copy to .env and fill in the values you need.
#
#   cp .env.example .env
#
# Only OPENROUTER_API_KEY is required for the AI-powered features. Everything
# else has sensible defaults or only activates if you've set up the optional
# integration.

# ---------------------------------------------------------------------------
# Required for AI features (LLM classification, thread intelligence, briefs)
# ---------------------------------------------------------------------------
# Get a key at https://openrouter.ai — pay-as-you-go, ~$0.05 / unified brief.
# Without it: classify, thread-intel, briefs, and unified signals will fail.
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Dashboard server
# ---------------------------------------------------------------------------
# Port for the Express dashboard. Defaults to 3000 if unset.
# PORT=3000

# Base URL the CLI uses to push reports/toasts to the running dashboard.
# Defaults to http://localhost:3000.
# SIGNALS_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Optional: Neo4j (graph-based scoring + cross-source corroboration)
# ---------------------------------------------------------------------------
# If NEO4J_PASSWORD is unset, the graph-scorer falls back to SQLite-only
# paths silently. To enable, point this at a running Neo4j instance.
# NEO4J_URL=http://localhost:7474
# NEO4J_DATABASE=neo4j
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=

# ---------------------------------------------------------------------------
# Optional: GitHub (raises rate limits for the GitHub + Anthropic producers)
# ---------------------------------------------------------------------------
# A classic or fine-grained PAT with public-repo read access is enough.
# Without it, requests use the lower unauthenticated rate limit.
# GITHUB_TOKEN=
